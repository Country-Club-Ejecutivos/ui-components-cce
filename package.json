{
  "name": "@countryclub/ui",
  "version": "0.5.0",
  "main": "dist/index.js",
  "module": "dist/index.mjs",
  "types": "dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.mjs",
      "require": "./dist/index.js"
    },
    "./tokens.css": "./dist/tokens.css",
    "./assets/*": "./dist/assets/*"
  },
  "scripts": {
    "build": "tsup && node scripts/copy-assets.js"
  },
  "dependencies": {
    "class-variance-authority": "^0.7.1",
    "clsx": "^2.1.1",
    "radix-ui": "^1.4.3",
    "tailwind-merge": "^3.6.0",
    "tw-animate-css": "^1.4.0"
  },
  "publishConfig": {
    "registry": "https://npm.pkg.github.com",
    "access": "restricted"
  },
  "peerDependencies": {
    "cmdk": ">=1",
    "lucide-react": ">=0.300.0",
    "next": ">=14",
    "react": ">=18",
    "sonner": ">=2",
    "tailwindcss": ">=4"
  },
  "devDependencies": {
    "@types/react": "^19",
    "tsup": "^8",
    "typescript": "^5"
  },
  "pnpm": {
    "onlyBuiltDependencies": [
      "esbuild",
      "sharp"
    ],
    "approvedBuilds": [
      "esbuild",
      "sharp"
    ]
  }
}
